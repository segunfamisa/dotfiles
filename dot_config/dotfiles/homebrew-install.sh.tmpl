#!/usr/bin/env bash
set -euo pipefail

# Re-run this script when the Brewfile changes.
# Brewfile checksum: {{ include "dot_config/homebrew/brewfile" | sha256sum }}

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is not installed; skipping brew bundle."
  exit 0
fi

brew bundle --file "$HOME/.config/homebrew/brewfile"
