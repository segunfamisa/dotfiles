#!/usr/bin/env bash
set -euo pipefail

# Re-run this script when the Brewfile changes.
# Brewfile checksum: {{ include "dot_config/homebrew/brewfile" | sha256sum }}

if ! command -v brew >/dev/null 2>&1; then
  cat <<'EOF'
Homebrew is not installed, so the Brewfile cannot be installed.

Install Homebrew first:

  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

Then re-run:

  bash ~/.config/dotfiles/homebrew-install.sh
EOF
  exit 0
fi

echo "Installing Homebrew packages from ~/.config/homebrew/brewfile..."
HOMEBREW_NO_ENV_HINTS=1 brew bundle --file "$HOME/.config/homebrew/brewfile"
