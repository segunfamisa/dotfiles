# jjui user config shared by chezmoi.
# Applied to: ~/.config/jjui/config.toml

[preview]
# Let jjui pick right/bottom based on terminal dimensions.
position = "auto"
show_at_start = false
width_percentage = 50.0
width_increment_percentage = 5.0

[oplog]
limit = 200

[suggest.exec]
# Fuzzy suggestions in jjui's `:` and `$` command prompts.
mode = "fuzzy"

[ui]
# Theme auto-switched to match Ghostty's light/dark detection.
# Selected by chezmoi data.theme (default "tokyonight"; "catppuccin" also available).
# Theme files live in ~/.config/jjui/themes/*.toml
{{- $theme := index . "theme" | default "tokyonight" }}
{{- if eq $theme "catppuccin" }}
theme = { dark = "catppuccin-mocha", light = "catppuccin-latte" }
{{- else }}
theme = { dark = "tokyonight-night", light = "tokyonight-day" }
{{- end }}
# Auto-refresh the view every N seconds (0 disables).
auto_refresh_interval = 3
set_window_title = true
mouse_support = true
flash_message_display_seconds = 4
